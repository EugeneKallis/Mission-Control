{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "types": ["bun"]
  },
  "include": [
    "next-env.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "**/*.test.ts",
    "**/*.test.tsx"
  ],
  // Exclude `scripts` so the script sources are not type-checked here.
  // The scripts are checked by the separate `tsconfig.scripts.json`
  // project (run by `just typecheck`). `node_modules` and `.next` are
  // excluded for build/perf reasons.
  "exclude": [
    "node_modules",
    "scripts",
    ".next"
  ]
}
