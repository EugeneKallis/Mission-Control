{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "types": ["bun"]
  },
  "include": [
    "next-env.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "**/*.test.ts",
    "**/*.test.tsx"
  ],
  // src/lib/db/test-helpers.ts lives under src/ on purpose — it lets the
  // test code use the @/lib/... path aliases. It is test-only and safe to
  // include in typechecking; do not add it to `exclude` (an exclude entry
  // cannot remove a file matched by the include glob).
  "exclude": [
    "node_modules",
    "scripts",
    ".next"
  ]
}
