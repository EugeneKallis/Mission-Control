# Mission Control — Environment
# Copy to .env and fill in your values

DATABASE_URL="file:./prisma/dev.db"
WEB_PORT=8080

# Media paths
RCLONE_PATH="/mnt/addons/debrid/__all__"
MEDIA_BASE_PATH="/mnt/debrid/media/"
MEDIA_DIRECTORIES="movies,movies4k,moviesanime,movieskids,movieslocal,special,tv,tv4k,tvanime,tvkids,tvlocal"

# External Services
DECYPHARR_URL="http://192.168.1.99:8282"
REAL_DEBRID_API_KEY=

# Plex
PLEX_TOKEN=
PLEX_URL=
PLEX_WATCHLIST_RSS=

# Trakt
TRAKT_CLIENT_ID=
TRAKT_CLIENT_SECRET=

